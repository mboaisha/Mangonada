#!/bin/sh
# Seed missing /etc/skel files into $HOME, then exec mango.
# Ensures default configs (e.g. mango/config.conf) are in place before
# mango starts reading them, which eliminates a first-login race for
# existing users created before those defaults were added to /etc/skel.
cd /etc/skel && find . -type f | while read -r f; do
	dst="$HOME/${f#./}"
	[ -e "$dst" ] || { mkdir -p "$(dirname "$dst")"; cp -p "$f" "$dst"; }
done
exec /usr/bin/mango "$@"
